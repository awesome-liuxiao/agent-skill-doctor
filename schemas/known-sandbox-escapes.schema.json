{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-skill-doctor.dev/schemas/v1/known-sandbox-escapes.schema.json",
  "title": "Known sandbox escape register",
  "type": "object",
  "required": ["schema_version", "reviewed_at", "entries"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "reviewed_at": {"type": "string", "format": "date-time"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "status", "platforms", "disclosure"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "severity": {"enum": ["low", "medium", "high", "critical"]},
          "status": {"enum": ["open", "fixed", "accepted"]},
          "platforms": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["windows", "macos", "linux"]}},
          "disclosure": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
