{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-skill-doctor.dev/schemas/v1/evals.schema.json",
  "title": "Agent Skill Evaluation Contract",
  "type": "object",
  "required": ["version", "tests"],
  "properties": {
    "version": {"const": 1},
    "skill": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {"$ref": "#/$defs/test"}
    }
  },
  "patternProperties": {
    "^x-[A-Za-z0-9_.-]+$": true
  },
  "additionalProperties": false,
  "$defs": {
    "pathArray": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2000,
        "not": {"pattern": "(^[/\\\\])|(^|[/\\\\])\\.\\.([/\\\\]|$)"}
      }
    },
    "stringArray": {
      "type": "array",
      "maxItems": 100,
      "items": {"type": "string", "minLength": 1, "maxLength": 2000}
    },
    "expected": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "exit_code": {"type": "integer", "minimum": -255, "maximum": 255},
        "output_contains": {"$ref": "#/$defs/stringArray"},
        "output_regex": {
          "type": "array",
          "maxItems": 100,
          "items": {"type": "string", "minLength": 1, "maxLength": 500}
        },
        "files_exist": {"$ref": "#/$defs/pathArray"},
        "files_absent": {"$ref": "#/$defs/pathArray"}
      },
      "additionalProperties": false
    },
    "test": {
      "type": "object",
      "required": ["id", "prompt", "expected"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
        },
        "prompt": {"type": "string", "minLength": 1, "maxLength": 20000},
        "expected": {"$ref": "#/$defs/expected"},
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "tags": {
          "type": "array",
          "maxItems": 100,
          "items": {"type": "string", "minLength": 1, "maxLength": 128}
        }
      },
      "additionalProperties": false
    }
  }
}
