{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-skill-doctor.dev/schemas/v1/benchmark.schema.json",
  "title": "Versioned public benchmark manifest",
  "type": "object",
  "required": ["schema_version", "corpus_version", "license_policy", "cases", "licensed_upstream_sources"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "corpus_version": {"type": "string", "minLength": 1},
    "license_policy": {"type": "string", "minLength": 1},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/case"}
    },
    "licensed_upstream_sources": {
      "type": "array",
      "items": {"$ref": "#/$defs/source"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "gitObject": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "case": {
      "type": "object",
      "required": ["id", "path", "stratum", "languages", "origin", "license", "modification_history", "expected_rule_ids", "expected_coverage"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "stratum": {"type": "string", "minLength": 1},
        "languages": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "origin": {
          "type": "object",
          "required": ["type", "url", "commit"],
          "properties": {
            "type": {"enum": ["synthetic", "licensed-upstream"]},
            "url": {"type": ["string", "null"]},
            "commit": {"anyOf": [{"$ref": "#/$defs/gitObject"}, {"type": "null"}]}
          },
          "additionalProperties": false
        },
        "license": {
          "type": "object",
          "required": ["spdx", "path"],
          "properties": {
            "spdx": {"enum": ["Apache-2.0", "MIT", "BSD-2-Clause", "BSD-3-Clause", "CC0-1.0"]},
            "path": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        },
        "modification_history": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "expected_rule_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^ASD[0-9]{3}$"}},
        "expected_coverage": {
          "type": "object",
          "required": ["failed", "unsupported_contains"],
          "properties": {
            "failed": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
            "unsupported_contains": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["id", "repository", "commit", "git_tree", "path", "license", "license_path", "license_sha256", "vendored_snapshot_sha256", "ingestion"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "repository": {"type": "string", "format": "uri", "pattern": "^https://"},
        "commit": {"$ref": "#/$defs/gitObject"},
        "git_tree": {"$ref": "#/$defs/gitObject"},
        "path": {"type": "string", "minLength": 1},
        "license": {"type": "string", "minLength": 1},
        "license_path": {"type": "string", "minLength": 1},
        "license_sha256": {"$ref": "#/$defs/sha256"},
        "vendored_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "ingestion": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
