{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-skill-doctor.dev/schemas/v1/rule-pack.schema.json",
  "title": "Signed declarative rule-pack payload",
  "type": "object",
  "required": [
    "kind", "version", "ruleset_version", "issued_at", "expires_at",
    "minimum_tool_version", "rules"
  ],
  "properties": {
    "kind": {"const": "rule_pack"},
    "version": {"const": 1},
    "ruleset_version": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.+-]{0,127}$"},
    "issued_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "minimum_tool_version": {"type": "string", "minLength": 1},
    "rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "items": {
        "type": "object",
        "required": ["id", "title", "message", "literal", "severity", "case_sensitive"],
        "properties": {
          "id": {"type": "string", "pattern": "^ASD[0-9]{3}$"},
          "title": {"type": "string", "minLength": 1, "maxLength": 200},
          "message": {"type": "string", "minLength": 1, "maxLength": 2000},
          "literal": {"type": "string", "minLength": 2, "maxLength": 256},
          "severity": {"enum": ["info", "low", "medium", "high", "critical"]},
          "case_sensitive": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
